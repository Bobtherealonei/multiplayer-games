# Copy to `.env` for local dev. Render uses its dashboard for env vars instead.

# REQUIRED — Redis connection. The game-server fails fast on startup if
# this is missing.
#   Local:  REDIS_URL=redis://localhost:6379
#   Render: pulled from your Render Key/Value service.
REDIS_URL=redis://localhost:6379

# Optional. Lets you run the game-server alongside other apps on the same
# Redis without key collisions. Defaults to "ts:".
REDIS_KEY_PREFIX=ts:

# Required for /factcheck and /judge.
PERPLEXITY_API_KEY=

# Required for /coach.
OPENAI_API_KEY=

# Required to read trending topics + record per-user "seen" debate questions.
# Paste the FULL service-account JSON on a single line, or set
# FIREBASE_SERVICE_ACCOUNT_PATH instead.
FIREBASE_SERVICE_ACCOUNT_JSON=

# CORS origin for the Socket.IO server. "*" is fine for dev.
CLIENT_URL=*

# Render injects PORT automatically; override locally if you like.
PORT=3000
